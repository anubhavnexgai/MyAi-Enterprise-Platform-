# ----------------------------------------------------------------------------
# MyAi-Enterprise - Local development settings
# Copy to .env and adjust as needed.
# ----------------------------------------------------------------------------

# ---- Runtime ----
APP_NAME=MyAi-Enterprise
APP_ENV=development
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=INFO

# Bypass SSO for local dev. Set to false to require a real Azure AD login.
DEV_MODE=true
DEV_USER_ID=dev.user
DEV_USER_EMAIL=dev.user@nexgai.com
DEV_USER_NAME=Dev User
DEV_TENANT_ID=nexgai
DEV_USER_ROLES=admin,supervisor,agent

# ---- Security ----
# PRODUCTION: set DEV_MODE=false and generate fresh secrets:
#   JWT_SECRET_KEY / SESSION_SECRET: python -c "import secrets; print(secrets.token_urlsafe(64))"
#   FERNET_KEY (below):              python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The defaults below are LOCAL-DEV ONLY and must not be used in production.
JWT_SECRET_KEY=change-me-in-prod-this-is-only-for-local-dev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
SESSION_SECRET=change-me-too-please

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:8002,http://127.0.0.1:8002

# ---- Database ----
# Leave DATABASE_URL empty to use the local SQLite fallback at data/myai_enterprise.db
DATABASE_URL=
SQLITE_PATH=data/myai_enterprise.db

# ---- Azure AD / OIDC (only used when DEV_MODE=false) ----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8002/api/auth/sso/callback

# ---- LLM provider ----
# llm_provider="ollama"        -> local dev (uses OLLAMA_* below)
# llm_provider="openai_compat" -> cloud-hosted open-weights model (vLLM /
#   llama.cpp server / Together / a self-hosted NexgAI SLM endpoint). This is
#   the production path: data stays inside NexgAI infra, no frontier API.
LLM_PROVIDER=ollama
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=120

# ---- Ollama (local dev fallback) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# ---- Correctness spine (grounding verification) ----
# When true, data-derived chat answers get a cheap second LLM pass that flags
# claims unsupported by the fetched connector context. Fail-open.
GROUNDING_VERIFY_ENABLED=true

# ---- Connector OAuth ----
# A single Google OAuth client (with all scopes enabled in Cloud Console) is
# reused for Gmail, Calendar and Drive. Per-provider redirect URIs are kept
# so you can split clients later if needed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:8002/api/connectors/google_gmail/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8002/api/connectors/google_calendar/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8002/api/connectors/google_drive/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8002/api/connectors/microsoft_graph/callback

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8002/api/connectors/slack/callback

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8002/api/connectors/notion/callback

# Fernet symmetric key used to encrypt OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left empty, a key is derived from JWT_SECRET_KEY (DEV ONLY).
FERNET_KEY=

# ---- Tenant config ----
TENANT_CONFIG_DIR=config/tenants
DEFAULT_TENANT_ID=nexgai
