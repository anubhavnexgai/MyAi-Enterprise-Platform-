# ════════════════════════════════════════════════════════════════════
#  MyAi-Enterprise — Cloud deployment config
#  Copy to .env on your cloud host and fill in real values.
# ════════════════════════════════════════════════════════════════════

# Runtime
APP_NAME=MyAi-Enterprise
APP_ENV=production
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=INFO

# IMPORTANT: turn this OFF in cloud — Azure AD SSO takes over
DEV_MODE=false

# Strong random secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET_KEY=
SESSION_SECRET=
FERNET_KEY=

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://myai.nexgai.com,https://teams.microsoft.com

# ── Database ──────────────────────────────────────────────────────
# Use a managed Postgres (Azure Database for PostgreSQL, RDS, etc.)
DATABASE_URL=postgresql+asyncpg://myai_app:STRONG_PASSWORD@db.example.com:5432/myai_enterprise

# ── LLM provider (hosted SLM) ─────────────────────────────────────
# Switch to openai_compat to talk to vLLM / Anyscale / Together / your
# own NexgAI SLM endpoint. Local Ollama is NOT used in cloud.
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://slm.nexgai.cloud/v1
LLM_API_KEY=
LLM_MODEL=nexgai-slm-7b
LLM_TIMEOUT=120

# ── File storage ──────────────────────────────────────────────────
# Pick S3 or Azure Blob
STORAGE_BACKEND=azure_blob
AZURE_STORAGE_ACCOUNT=myaienterprise
AZURE_CONTAINER=user-files
# or
# STORAGE_BACKEND=s3
# S3_BUCKET=myai-enterprise
# S3_REGION=us-east-1

# ── Azure AD SSO ──────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://myai.nexgai.com/api/auth/sso/callback

# ── Connector OAuth (Google, Microsoft, Slack, Notion) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_GMAIL_REDIRECT_URI=https://myai.nexgai.com/api/connectors/google_gmail/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://myai.nexgai.com/api/connectors/google_calendar/callback
GOOGLE_DRIVE_REDIRECT_URI=https://myai.nexgai.com/api/connectors/google_drive/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://myai.nexgai.com/api/connectors/microsoft_graph/callback

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://myai.nexgai.com/api/connectors/slack/callback

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://myai.nexgai.com/api/connectors/notion/callback

# ── Tenants ───────────────────────────────────────────────────────
DEFAULT_TENANT_ID=nexgai
